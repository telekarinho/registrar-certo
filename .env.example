# ===========================================
# Registrar Certo — Variáveis de Ambiente
# ===========================================
# Copie este arquivo como .env.local para desenvolvimento

# --- Banco de Dados ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/registrarcerto?schema=public"
TEST_DATABASE_URL="postgresql://postgres:postgres@localhost:5432/registrarcerto_test?schema=public"

# --- Redis ---
REDIS_URL="redis://localhost:6379"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="gere-uma-chave-secreta-aqui-com-openssl-rand-base64-32"

# --- E-mail (SMTP) ---
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@registrarcerto.com.br"
SMTP_PASSWORD=""
SMTP_FROM="Registrar Certo <noreply@registrarcerto.com.br>"

# --- OpenAI (para camada de IA) ---
OPENAI_API_KEY=""
OPENAI_MODEL_PRIMARY="gpt-4o-mini"
OPENAI_MODEL_FALLBACK="gpt-4o"

# --- Microserviço de Busca INPI ---
INPI_SEARCH_URL="http://localhost:3001"
INPI_SEARCH_ENABLED="true"
INPI_SEARCH_CACHE_TTL_SECONDS="86400"

# --- Armazenamento (S3-compatible) ---
S3_ENDPOINT=""
S3_BUCKET="registrarcerto"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="us-east-1"

# --- Analytics ---
NEXT_PUBLIC_GA_ID=""

# --- Feature Flags (defaults) ---
FF_INPI_SEARCH="true"
FF_AI_TRIAGE="true"
FF_PDF_GENERATION="true"
FF_EMAIL_NOTIFICATIONS="true"

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Registrar Certo"
NODE_ENV="development"
LOG_LEVEL="debug"
